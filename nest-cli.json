{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "projects": {
    "wallet-service": {
      "type": "application",
      "root": "wallet-service",
      "entryFile": "main",
      "sourceRoot": "wallet-service/src",
      "compilerOptions": {
        "tsConfigPath": "wallet-service/tsconfig.json",
        "outputPath": "dist/wallet-service"
      }
    },
    "user-service": {
      "type": "application",
      "root": "user-service",
      "entryFile": "main",
      "sourceRoot": "user-service/src",
      "compilerOptions": {
        "tsConfigPath": "user-service/tsconfig.json",
        "outputPath": "dist/user-service"
      }
    },
    "gateway-service": {
      "type": "application",
      "root": "gateway-service",
      "entryFile": "main",
      "sourceRoot": "gateway-service/src",
      "compilerOptions": {
        "tsConfigPath": "gateway-service/tsconfig.json",
        "outputPath": "dist/gateway-service"
      }
    }
  }
}
